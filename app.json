{
  "expo": {
    "name": "hälsoPilot",
    "slug": "halsopilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#3D7A8A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.halsopilot.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely access your health data.",
        "NSCameraUsageDescription": "Used for scanning medication labels and capturing health cards."
      }
    },
    "android": {
      "package": "com.halsopilot.app",
      "adaptiveIcon": {
        "backgroundColor": "#3D7A8A"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-local-authentication",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "5b56312a-1fe8-4c93-85e9-bd01ea003410"
      }
    },
    "owner": "pixeljuggernaut"
  }
}
